# 複製為 .env（勿 commit）

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY=1

# --- Cursor API（Hermes 大腦，走 Cursor 額度，非 OpenAI）---
# 取得： https://cursor.com/dashboard → Integrations → User API Keys
CURSOR_API_KEY=
HERMES_LLM_PROVIDER=cursor
HERMES_CURSOR_MODEL=composer-2

# --- 剪報雙語（LibreTranslate 可選 + Cursor LLM 備援）---
# HERMERS_TRANSLATE=1          # 設 0 可關閉 LibreTranslate，仍可用 LLM
# HERMERS_TRANSLATE_LLM=1      # 設 0 可關閉 LLM batch 翻譯（需 CURSOR_API_KEY + Node bridge）
# LIBRETRANSLATE_URL=https://libretranslate.de/translate

# --- GitHub（可選；建議 gh auth login）---
GITHUB_TOKEN=

# 對外剪報站（Bot /status 會即時 GET 此網址確認是否上線）
SITE_PUBLIC_URL=https://penghermers.pengczeczec.workers.dev

# --- Cloudflare Worker（路線二；設在儀表板 / wrangler secret，勿 commit）---
# 自動設定 Builds（deploy 指令、SKIP_DEPENDENCY_INSTALL）：python tools/configure_cloudflare_builds.py
# CLOUDFLARE_API_TOKEN=   # My Profile → API Tokens → Workers Builds Configuration (Edit)
# CLOUDFLARE_ACCOUNT_ID=  # 儀表板 URL 或 Workers 概覽中的 Account ID
# PIPELINE_WEBHOOK_URL=   # 例如 GitHub Actions workflow_dispatch 的觸發網址
# CRON_SECRET=            # 若設定，POST /api/trigger 需 Authorization: Bearer …
