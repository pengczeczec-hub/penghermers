# 複製為 .env 並填入（.env 不會被 commit）
# GitHub：可選。若 401 或過期，請刪除此行並改用 gh auth login
# 或執行：gh auth token  將輸出貼到下方（勿 commit）
GITHUB_TOKEN=

# Telegram 通知（@BotFather 建立 Bot 後取得）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 1=啟用通知（預設）；設 0 可關閉
TELEGRAM_NOTIFY=1

# 可選：已上線的剪報站網址，會一併寫進 Telegram 訊息
# SITE_PUBLIC_URL=https://xxx.pages.dev

# Hermes 推送目標見 config/hermes.yaml（預設 auto-news-site）
